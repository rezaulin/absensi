# ============================================================
# e-Pesantren SaaS — Environment Configuration
# Copy file ini ke .env dan sesuaikan nilainya
# ============================================================

# Database
DB_HOST=localhost
DB_USER=epesantren
DB_PASS=ganti-password-database-anda
DB_NAME=epesantren_saas
DB_PORT=3306

# Server
PORT=3000
NODE_ENV=production

# JWT Secret (WAJIB GANTI untuk production!)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti-dengan-random-string-yang-sangat-panjang-dan-aman

# Domain utama (tanpa http/https)
DOMAIN=e-pesantren.app

# Super Admin credentials (WAJIB GANTI untuk production!)
SUPER_ADMIN_USER=superadmin
SUPER_ADMIN_PASS=ganti-password-super-admin

# Logging
LOG_LEVEL=info

# File upload max size (in MB)
MAX_UPLOAD_SIZE=10
